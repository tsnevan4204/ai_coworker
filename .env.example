# OpenAI (LLM + embeddings + TTS)
OPENAI_API_KEY=

# Qdrant (optional for Recall POC — leave QDRANT_URL empty to skip)
# Cloud example: https://xxxxxxxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=

# Recall.ai
RECALL_API_KEY=
RECALL_VERIFICATION_SECRET=
RECALL_REGION=us-west-2

# Tavily
TAVILY_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Google (Calendar + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Resend
RESEND_API_KEY=
EMAIL_FROM=yaco@yourdomain.com

# App config
PUBLIC_BASE_URL=https://your-ngrok-or-deploy-url.com
BOT_NAME=Yaco
SPEAK_COOLDOWN_SECS=90
DOC_RELEVANCE_THRESHOLD=0.82
IDEA_CONFIRMATION_WINDOW_SECS=20
MIN_CHUNK_WORDS=15
CALENDAR_POLL_INTERVAL_MINS=5
TRANSCRIPTS_DIR=./transcripts
